# OpenGPU Agent Configuration
# Copy this file to .env and fill in your values

# Required: Your API key from the OpenGPU dashboard
OPENGPU_API_KEY=your-api-key-here

# API endpoint (default: https://api.opengpu.network)
OPENGPU_API_ENDPOINT=https://api.opengpu.network

# Node name (default: hostname)
OPENGPU_NODE_NAME=my-gpu-node

# Maximum concurrent rentals (default: 4)
OPENGPU_MAX_RENTALS=4

# Heartbeat interval in milliseconds (default: 30000)
OPENGPU_HEARTBEAT_INTERVAL=30000

# Metrics collection interval in milliseconds (default: 5000)
OPENGPU_METRICS_INTERVAL=5000

# Data directory (default: ~/.opengpu/data)
OPENGPU_DATA_DIR=/root/.opengpu/data

# Docker runtime (default: nvidia)
OPENGPU_DOCKER_RUNTIME=nvidia

# Network interface for bandwidth monitoring (default: eth0)
OPENGPU_NETWORK_INTERFACE=eth0

# Enable VPN isolation (default: false)
OPENGPU_ENABLE_VPN=false

# Log level (default: info)
# Options: error, warn, info, debug
OPENGPU_LOG_LEVEL=info

# Log directory (default: ~/.opengpu/logs)
OPENGPU_LOG_DIR=/root/.opengpu/logs
