{
  "name": "opengpu",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source GPU cloud marketplace - rent and share GPU power",
  "license": "AGPL-3.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:agent": "npm run dev --workspace=packages/agent",
    "dev:desktop": "npm run dev --workspace=apps/desktop",
    "build": "concurrently \"npm run build:shared\" \"npm run build:api\" \"npm run build:web\"",
    "build:shared": "npm run build --workspace=packages/shared",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "build:desktop": "npm run build --workspace=apps/desktop",
    "build:agent": "npm run build --workspace=packages/agent",
    "build:cli": "npm run build --workspace=packages/cli",
    "start": "npm run start --workspace=apps/api",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "concurrently": "^8.2.2",
    "husky": "^9.0.6",
    "jest": "^29.7.0",
    "typescript": "^5.3.3"
  }
}
