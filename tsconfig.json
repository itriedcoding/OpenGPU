{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@opengpu/shared": ["./packages/shared/src"],
      "@opengpu/api": ["./apps/api/src"],
      "@opengpu/web": ["./apps/web/src"]
    }
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
