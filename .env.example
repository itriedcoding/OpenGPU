# ============================================
# OpenGPU Environment Configuration
# ============================================
# Copy this file to .env and fill in the values

# ============================================
# API Configuration
# ============================================
API_PORT=3000
API_HOST=0.0.0.0
API_URL=http://localhost:3000

# ============================================
# Database Configuration
# ============================================
# Using SQLite by default (no configuration needed)
# For PostgreSQL, uncomment and configure:
# DATABASE_URL=postgresql://user:password@localhost:5432/opengpu
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=opengpu
# DB_USER=postgres
# DB_PASSWORD=your_password

# ============================================
# Redis Configuration (Optional)
# ============================================
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ============================================
# Authentication
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d
API_KEY_PREFIX=ogpu_

# ============================================
# GPU Agent Configuration
# ============================================
AGENT_PORT=4000
AGENT_HEARTBEAT_INTERVAL=30000
AGENT_MAX_GPUS=8

# ============================================
# Payment & Billing
# ============================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ============================================
# Storage (Optional)
# ============================================
# AWS_S3_BUCKET=opengpu-uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ============================================
# Monitoring (Optional)
# ============================================
# SENTRY_DSN=
# DATADOG_API_KEY=
# PROMETHEUS_ENABLED=false

# ============================================
# Development
# ============================================
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGIN=*
ENABLE_SWAGGER=true
