# ============================================
# OpenGPU Agent Dockerfile
# ============================================

# Build stage
FROM node:20-alpine AS builder

WORKDIR /app

# Copy package files
COPY packages/agent/package*.json ./packages/agent/
COPY package*.json ./
COPY tsconfig*.json ./

# Install dependencies
RUN npm ci --workspace=@opengpu/agent

# Copy source code
COPY packages/agent/ ./packages/agent/

# Build the application
RUN npm run build --workspace=@opengpu/agent

# Production stage
FROM node:20-alpine AS production

# Add tini for proper signal handling
RUN apk add --no-cache tini

# Add NVIDIA runtime support (optional)
# Uncomment if GPU passthrough is needed
# RUN apk add --no-cache nvidia-container-toolkit

# Create app user
RUN addgroup -g 1001 -S opengpu && \
    adduser -S opengpu -u 1001

WORKDIR /app

# Copy package files
COPY packages/agent/package*.json ./

# Install production dependencies only
RUN npm ci --omit=dev && npm cache clean --force

# Copy built application
COPY --from=builder /app/packages/agent/dist ./dist

# Create necessary directories
RUN mkdir -p /app/logs /app/tmp && chown -R opengpu:opengpu /app

# Switch to non-root user
USER opengpu

# Expose port
EXPOSE 4000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:4000/health || exit 1

# Start the application
ENTRYPOINT ["/sbin/tini", "--"]
CMD ["node", "dist/index.js"]
